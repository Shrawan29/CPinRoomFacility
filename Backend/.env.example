PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<dbName>?retryWrites=true&w=majority
JWT_ADMIN_SECRET=change_me
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Chat bot (guest) — restricted to menu + events only
# Required to enable POST /guest/chat
OPENAI_API_KEY=

# Optional base URL (only if using a proxy / compatible endpoint)
# OpenRouter example:
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_BASE_URL=

# Optional model
# - OpenAI direct examples:    gpt-4o-mini, o3-mini
# - OpenRouter examples:       openai/gpt-oss-120b:free, openai/o3-mini
OPENAI_MODEL=

# Optional: force (or disable) using the OpenAI Responses API.
# - Leave empty for auto-detect (o-series models typically use Responses).
# - Set true to force, false to disable.
OPENAI_USE_RESPONSES_API=

# OpenRouter (optional but recommended by OpenRouter)
# Set your frontend/app origin and a friendly app name for analytics.
OPENROUTER_REFERER=http://localhost:5173
OPENROUTER_APP_NAME=CPinRoomFacility

# Optional OpenRouter provider routing (advanced)
# If your OpenRouter account privacy settings enforce these, you may see:
#   "404 ... no endpoints found matching your data policy"
# You can set per-request preferences here (account-wide ZDR may still override).
# OPENROUTER_DATA_COLLECTION=allow
# OPENROUTER_ZDR=false
# OPENROUTER_REQUIRE_PARAMETERS=false
# OPENROUTER_ALLOW_FALLBACKS=true

# Rannkly Forms integration (guest feedback/suggestion -> Rannkly dashboard)
# Do not hardcode secrets in source code. Keep API key in env only.
RANNKLY_ENABLED=false
RANNKLY_API_KEY=
RANNKLY_BASE_URL=https://forms.rannkly.com/external-api/v1
RANNKLY_FORM_ID=

# Required if your API key is global (see Rannkly docs)
RANNKLY_TEAM_ID=

# Which complaint types should sync (case-insensitive).
# Default in code is: feedback,suggestion
RANNKLY_SYNC_TYPES=feedback,suggestion

# Map your app fields -> Rannkly question IDs.
# Supported source keys: type, category, subject, message, guestName, roomNumber, complaintId
# Example:
# RANNKLY_QUESTION_MAP_JSON={"type":"q_type","category":"q_category","subject":"q_subject","message":"q_feedback","guestName":"q_guest","roomNumber":"q_room","complaintId":"q_external_id"}
RANNKLY_QUESTION_MAP_JSON=

# Optional equivalent per-field mapping (used together with / as fallback to JSON mapping)
RANNKLY_Q_TYPE_ID=
RANNKLY_Q_CATEGORY_ID=
RANNKLY_Q_SUBJECT_ID=
RANNKLY_Q_MESSAGE_ID=
RANNKLY_Q_GUEST_NAME_ID=
RANNKLY_Q_ROOM_ID=
RANNKLY_Q_COMPLAINT_ID=

# Optional extra metadata to store in hiddenFields with each submission
# Example: {"property":"CPinRoomFacility","channel":"in_room_app"}
RANNKLY_EXTRA_HIDDEN_FIELDS_JSON=

# Optional UTM tracking fields
RANNKLY_UTM_SOURCE=
RANNKLY_UTM_MEDIUM=
RANNKLY_UTM_CAMPAIGN=
RANNKLY_UTM_TERM=
RANNKLY_UTM_CONTENT=

# Optional timeout for API call
RANNKLY_REQUEST_TIMEOUT_MS=10000

# Twilio voice alerts (housekeeping supervisor automated call)
# Keep disabled until all values are configured.
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional: if set, housekeeping alerts trigger this Twilio Studio Flow execution.
# Example: FW6388a792dec59d151e072e541866c532
TWILIO_STUDIO_FLOW_SID=

# Default supervisor phone number (E.164 format, e.g. +9179xxxxxxxx)
HOUSEKEEPING_SUPERVISOR_DEFAULT_TO=+917972895563

# Optional floor mapping: 2 floors per supervisor or any custom ranges.
# Example: {"1-2":"+91XXXXXXXXXX","3-4":"+91YYYYYYYYYY"}
HOUSEKEEPING_SUPERVISOR_FLOOR_MAP_JSON=

# Escalation sequence:
# 1) Instant app notification (dashboard polling)
# 2) First call if not accepted after delay (60-90s recommended)
# 3) Escalation call if still no accept in 3 minutes
HOUSEKEEPING_CALL_DELAY_MS=75000
HOUSEKEEPING_ESCALATION_DELAY_MS=180000
HOUSEKEEPING_ESCALATION_TO=

# Optional: use your own TwiML URL; if empty, code sends inline TwiML message.
# This is used only when TWILIO_STUDIO_FLOW_SID is empty.
TWILIO_HOUSEKEEPING_URL=
TWILIO_HOUSEKEEPING_VOICE=alice
TWILIO_HOUSEKEEPING_LANGUAGE=en-IN
TWILIO_REQUEST_TIMEOUT_MS=10000
